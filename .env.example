# Copy this file to .env and fill in real values
# .env is gitignored and will not be committed

# Siemens LLM API
SIEMENS_API_KEY=your-api-key-here
SIEMENS_API_ENDPOINT=https://api.siemens.ai/v1/chat/completions

# Model routing (any available model can be used in any slot)
LLM_MODEL_PRIMARY=deepseek-v4-flash
LLM_MODEL_NARRATIVE=gpt-oss-120b
LLM_MODEL_FALLBACK=qwen-3.6-27b
